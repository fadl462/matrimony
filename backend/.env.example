# --- Database ---
# Local demo (SQLite): keep as-is, no setup needed.
DB_DIALECT="sqlite"
SQLITE_PATH="./dev.sqlite3"
# Production (Postgres):
# DB_DIALECT="postgres"
# DATABASE_URL="postgresql://user:password@host:5432/matrimony"
# PGSSL="true"

# --- Auth ---
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="7d"
BCRYPT_ROUNDS=12

# --- OAuth (fill in to go live; endpoints are wired, see routes/auth.js) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
OAUTH_REDIRECT_BASE_URL="http://localhost:5173/oauth/callback"

# --- Phone verification (Twilio recommended; wired as a pluggable interface) ---
SMS_PROVIDER="mock"          # "mock" | "twilio"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# --- Video storage (local disk for demo; swap for S3/Cloud Storage in prod) ---
VIDEO_STORAGE="local"        # "local" | "s3"
VIDEO_UPLOAD_DIR="./uploads/videos"
MAX_VIDEO_MB=100
S3_BUCKET=""
S3_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# --- App ---
PORT=4000
NODE_ENV="development"
CORS_ORIGIN="http://localhost:5173"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
